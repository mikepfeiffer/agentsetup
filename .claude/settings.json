{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.agent-hooks/agent-hook.mjs",
              "pre-tool-policy"
            ],
            "timeout": 30,
            "statusMessage": "Checking repository hook policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.agent-hooks/agent-hook.mjs",
              "stop-validate"
            ],
            "timeout": 30,
            "statusMessage": "Validating shared agent setup"
          }
        ]
      }
    ]
  }
}
